# Neon Agent Framework env example
#
# Copy to `.env` for local runs, or to `~/.neon-agent/.env` for daemon runs.
# Fill only the providers/channels you use.
# Never commit real secrets.

# Model providers
# OPENAI_API_KEY=<openai-api-key>
# ANTHROPIC_API_KEY=<anthropic-api-key>
# OPENROUTER_API_KEY=<openrouter-api-key>

# Discord channel
# DISCORD_BOT_TOKEN=...
# DISCORD_CHANNEL_ID=...

# Runtime paths
# NEON_AGENT_STATE_DIR=~/.neon-agent
# NEON_AGENT_CONFIG_PATH=~/.neon-agent/config.json
